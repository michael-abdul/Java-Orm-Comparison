<configuration>
    <jdbc>
        <driver>org.h2.Driver</driver>
        <url>jdbc:h2:mem:demo;MODE=MySQL;INIT=RUNSCRIPT FROM 'file:z:/java-orm-comparison/src/main/resources/schema-jooq.sql'</url>
        <username>sa</username>
        <password></password>
    </jdbc>

    <generator>
        <database>
            <name>org.jooq.meta.h2.H2Database</name>
            <includes>salary</includes>
            <excludes></excludes>
            <inputSchema>DEMO</inputSchema>
        </database>

        <generate>
            <pojos>true</pojos>
        </generate>

        <target>
            <packageName>win.doyto.ormcamparison.jooq</packageName>
        </target>
    </generator>
</configuration>
